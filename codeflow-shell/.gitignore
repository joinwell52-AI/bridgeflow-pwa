node_modules/
dist/
*.log
*.tmp

# Local config / secrets — never commit.
.env
codeflow.config.json

# But DO commit the env example — it is a user template.
# (Repo-root .gitignore line 71 has `.env.*` which would otherwise
# silently ignore `.env.example`; this re-include negates that for
# this subtree only.)
!.env.example

# Demo state — wiped on each run; not source code.
.smoke-test-state/
.sigint-test-state/
examples/hello-world/.codeflow-state/

# Smoke / dev-test scratch — never commit. (PM TASK-012 §5.5 defense:
# DEV / QA self-tests use ad-hoc dataDirs / log files like
# `.smoke-beta1/`, `.smoke-beta1-log.txt`, `.smoke-retry-1223/` that
# would otherwise pollute `git status` and risk being committed.)
.smoke-*
